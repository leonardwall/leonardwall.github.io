---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact | Leonard Wall" description="Contact Leonard Wall for advisory, speaking, and collaboration.">
  <section class="mx-auto max-w-content px-6 py-20">
    <p class="text-sm uppercase tracking-[0.22em] text-accent">Contact</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">For advisory, speaking, and strategic conversations</h1>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      <a href="https://www.linkedin.com" class="rounded-3xl border border-line bg-panel p-7 hover:border-accent">
        <h2 class="text-xl font-semibold text-text">LinkedIn</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Best for professional outreach and direct conversations.</p>
      </a>
      <a href="https://github.com/leonardwall" class="rounded-3xl border border-line bg-panel p-7 hover:border-accent">
        <h2 class="text-xl font-semibold text-text">GitHub</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Projects, code, frameworks, and technical work.</p>
      </a>
      <a href="mailto:hello@example.com" class="rounded-3xl border border-line bg-panel p-7 hover:border-accent">
        <h2 class="text-xl font-semibold text-text">Email</h2>
        <p class="mt-3 text-sm leading-7 text-muted">Replace with your preferred public contact address.</p>
      </a>
    </div>
  </section>
</BaseLayout>
