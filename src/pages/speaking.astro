---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('speaking')).sort((a, b) => b.data.eventDate.getTime() - a.data.eventDate.getTime());
---
<BaseLayout title="Speaking | Leonard Wall" description="Speaking topics and selected engagements from Leonard Wall.">
  <section class="mx-auto max-w-content px-6 py-20">
    <p class="text-sm uppercase tracking-[0.22em] text-accent">Speaking</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">Executive conversations, customer sessions, and thought leadership topics</h1>
    <div class="mt-10 space-y-5">
      {items.map((item) => (
        <div class="rounded-3xl border border-line bg-panel p-7">
          <p class="text-sm text-muted">{item.data.eventDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })} · {item.data.event}</p>
          <h2 class="mt-2 text-2xl font-semibold text-text">{item.data.title}</h2>
          <p class="mt-3 text-sm font-medium text-accent">{item.data.topic}</p>
          <p class="mt-3 text-sm leading-7 text-muted">{item.data.description}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
