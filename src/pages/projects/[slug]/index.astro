---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---
<BaseLayout title={`${project.data.title} | Leonard Wall`} description={project.data.description}>
  <article class="mx-auto max-w-3xl px-6 py-20">
    <p class="text-sm uppercase tracking-[0.22em] text-accent">Project</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">{project.data.title}</h1>
    <p class="mt-5 text-base leading-8 text-muted">{project.data.description}</p>
    {project.data.link && (
      <p class="mt-6"><a href={project.data.link} class="text-sm font-semibold text-accent">{project.data.cta ?? 'Open link'} →</a></p>
    )}
    <div class="prose prose-invert mt-10 max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
