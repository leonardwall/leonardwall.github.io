---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const insights = (await getCollection('insights'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);
const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);
---
<BaseLayout
  title="Leonard Wall | Security, Observability, and Platform Strategy"
  description="Executive advisor on security, observability, and resilient platform strategy."
>
  <section class="mx-auto max-w-content px-6 pb-20 pt-20 md:pt-28">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_.8fr] lg:items-end">
      <div>
        <p class="mb-4 text-sm font-medium uppercase tracking-[0.25em] text-accent">Executive advisor</p>
        <h1 class="max-w-4xl text-4xl font-semibold tracking-tight text-text md:text-6xl">
          Security and observability are converging.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-muted">
          I help technology leaders simplify operations, strengthen resilience, and build modern platform strategies across security, observability, and cloud.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/insights" class="rounded-full bg-accent px-5 py-3 text-sm font-semibold text-slate-900 hover:opacity-90">Read insights</a>
          <a href="/projects" class="rounded-full border border-line px-5 py-3 text-sm font-semibold text-text hover:border-accent hover:text-accent">View projects</a>
        </div>
      </div>
      <div class="rounded-3xl border border-line bg-panel p-6 shadow-soft">
        <p class="text-sm uppercase tracking-[0.22em] text-muted">Focus areas</p>
        <ul class="mt-5 space-y-4 text-sm text-muted">
          <li><span class="font-semibold text-text">Security + observability</span><br />Unifying telemetry, resilience, and response.</li>
          <li><span class="font-semibold text-text">Platform strategy</span><br />Reducing sprawl and increasing operating leverage.</li>
          <li><span class="font-semibold text-text">Executive advisory</span><br />Helping leaders translate technical complexity into strategic action.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-content px-6 pb-20">
    <div class="grid gap-6 md:grid-cols-4">
      {['Former Deputy CISO', 'Observability Advisor', 'Open Source Builder', 'Executive Storyteller'].map((item) => (
        <div class="rounded-2xl border border-line bg-panel/60 p-5 text-sm text-muted">{item}</div>
      ))}
    </div>
  </section>

  <section class="mx-auto grid max-w-content gap-10 px-6 pb-20 lg:grid-cols-2">
    <div>
      <p class="text-sm uppercase tracking-[0.22em] text-accent">Featured insights</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight">Ideas for leaders navigating complexity</h2>
      <div class="mt-6 space-y-5">
        {insights.map((post) => (
          <a href={`/insights/${post.slug}/`} class="block rounded-2xl border border-line bg-panel p-6 hover:border-accent">
            <p class="text-sm text-muted">{post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
            <h3 class="mt-2 text-xl font-semibold text-text">{post.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
    <div>
      <p class="text-sm uppercase tracking-[0.22em] text-accent">Featured projects</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight">Practical work, not abstract positioning</h2>
      <div class="mt-6 space-y-5">
        {projects.map((project) => (
          <a href={`/projects/${project.slug}/`} class="block rounded-2xl border border-line bg-panel p-6 hover:border-accent">
            <h3 class="text-xl font-semibold text-text">{project.data.title}</h3>
            <p class="mt-3 text-sm leading-7 text-muted">{project.data.description}</p>
            <p class="mt-4 text-sm font-medium text-accent">Explore project</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-content px-6 pb-24">
    <div class="rounded-3xl border border-line bg-panel p-8 md:p-10">
      <p class="text-sm uppercase tracking-[0.22em] text-accent">About Leonard</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight">A platform view shaped by security, operations, and executive leadership</h2>
      <p class="mt-5 max-w-3xl text-base leading-8 text-muted">
        Leonard Wall works at the intersection of security, observability, and enterprise platform strategy. His perspective is grounded in security leadership, executive advisory work, and a conviction that resilience now depends on better telemetry, cleaner operating models, and sharper strategic alignment.
      </p>
      <div class="mt-8">
        <a href="/about" class="text-sm font-semibold text-accent">Read full profile →</a>
      </div>
    </div>
  </section>
</BaseLayout>
