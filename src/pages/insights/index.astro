---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const insights = (await getCollection('insights')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="Insights | Leonard Wall" description="Writing on security, observability, platform strategy, and resilience.">
  <section class="mx-auto max-w-content px-6 py-20">
    <p class="text-sm uppercase tracking-[0.22em] text-accent">Insights</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">Writing on security, observability, and resilient platforms</h1>
    <div class="mt-10 space-y-6">
      {insights.map((post) => (
        <a href={`/insights/${post.slug}/`} class="block rounded-3xl border border-line bg-panel p-7 hover:border-accent">
          <p class="text-sm text-muted">{post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
          <h2 class="mt-2 text-2xl font-semibold text-text">{post.data.title}</h2>
          <p class="mt-3 max-w-3xl text-sm leading-7 text-muted">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
